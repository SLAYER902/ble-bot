{
  "name": "ble-bot",
  "version": "0.1.0",
  "private": true,
  "description": "BLE Bot is a defensive Discord platform with BLE Shield anti-nuke protection.",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12.0 <25",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "worker": "tsx src/worker.ts",
    "worker:start": "node dist/worker.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:security": "tsx scripts/security-simulation.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "commands:deploy:test": "tsx scripts/deploy-commands.ts --scope test",
    "commands:deploy:global": "tsx scripts/deploy-commands.ts --scope global",
    "commands:delete:test": "tsx scripts/delete-commands.ts --scope test",
    "commands:validate": "tsx scripts/validate-commands.ts",
    "env:validate": "tsx scripts/validate-environment.ts",
    "emoji:validate": "tsx scripts/validate-emojis.ts",
    "seed:development": "tsx scripts/seed-development.ts"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "bullmq": "^5.80.2",
    "discord.js": "^14.26.5",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.10.1",
    "pg": "^8.16.3",
    "pino": "^9.9.4",
    "pino-pretty": "^13.1.1",
    "prom-client": "^15.1.3",
    "ws": "8.18.3",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^24.3.1",
    "@types/pg": "^8.15.5",
    "@types/ws": "8.5.13",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vitest": "^3.2.4"
  }
}
